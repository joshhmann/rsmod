    "overview": {
        "description": "Experience (EXP/XP) is a measure of skill progress. Gained by performing skill-related tasks, quests, lamps, minigames, etc.",
        "storage": "Signed 32-bit integer treated as fixed-point with 1 decimal place",
        "display": "Game shows integer XP values; internally stored as tenths (e.g., 83 XP = 830 internally)",
        "max_xp_per_skill": 200000000,
        "max_internal": 2147483647,
        "level_cap": 99,
        "virtual_level_cap": 126,
        "xp_to_99": 13034431,
        "xp_to_92": 6517253,
        "rule_92_is_half_of_99": "Level 92 is almost exactly the halfway point to 99",
        "rule_85_is_quarter": "Level 85 requires approximately 1/4 of the XP needed for 99"
    },
    "formula": {
        "description": "XP required for level L (total cumulative XP to reach level L)",
        "formula": "XP(L) = floor(1/4 * sum(l=1 to L-1, floor(l + 300 * 2^(l/7))))",
        "note": "The sum is accumulated from level 1. Due to multiple floor operations the exact difference must be calculated per level.",
        "level_difference_approximate": "floor(L-1 + 300 * 2^((L-1)/7)) ±1",
        "xp_increase_per_level": "approximately 10% more each level",
        "doubling_every": "7 levels approximately doubles XP requirement (from level 30+)"
    },
