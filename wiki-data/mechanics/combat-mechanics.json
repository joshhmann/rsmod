  "formulas": {
    "description": "OSRS uses a two-roll combat system: accuracy roll first, then damage roll",
    "tick_system": {
      "duration_ms": 600,
      "duration_seconds": 0.6,
      "notes": "All actions synchronized to 600ms tick cycle. Client-side actions processed at 20ms."
    },

    "max_hit_melee": {
      "description": "Calculate maximum melee damage",
      "step_1_effective_strength": "floor((visible_strength_level * prayer_bonus) + style_bonus + 8)",
      "step_2_max_hit": "floor(0.5 + (effective_strength * (equipment_strength_bonus + 64) / 640))",
      "style_bonuses": {
        "accurate": 0,
        "aggressive": 3,
        "defensive": 0,
        "controlled": 1
      }
    },

    "accuracy_melee": {
      "description": "Calculate melee hit chance",
      "step_1_effective_attack": "floor((visible_attack_level * prayer_bonus) + style_bonus + 8)",
      "step_2_attack_roll": "floor(effective_attack * (equipment_attack_bonus + 64) / 64)",
      "step_3_defence_roll": "floor(effective_defence * (equipment_defence_bonus + 64) / 64)",
      "step_4_hit_chance": {
        "if_attack_greater": "1 - ((defence_roll + 1) / (2 * attack_roll))",
        "if_defence_greater_or_equal": "attack_roll / (2 * (defence_roll + 1))"
      }
    },

    "max_hit_ranged": {
      "description": "Calculate maximum ranged damage",
      "step_1_effective_ranged": "floor((visible_ranged_level * prayer_bonus) + style_bonus + 8)",
      "step_2_max_hit": "floor(0.5 + (effective_ranged * (equipment_ranged_bonus + 64) / 640))"
    },

    "accuracy_ranged": {
      "description": "Calculate ranged hit chance",
      "step_1_effective_ranged": "floor((visible_ranged_level * prayer_bonus) + style_bonus + 8)",
      "step_2_attack_roll": "floor(effective_ranged * (equipment_ranged_bonus + 64) / 64)",
      "step_3_defence_roll": "floor(effective_defence * (equipment_defence_bonus + 64) / 64)",
      "step_4_hit_chance": "Same as melee accuracy formula"
    },

    "max_hit_magic": {
      "description": "Calculate maximum magic damage (spell-based)",
      "base_spell_damage": "Defined per spell",
      "equipment_bonus_multiplier": "(magic_damage_bonus / 100) + 1",
      "step_1_max_hit": "floor(spell_max_hit * equipment_multiplier)"
    },

    "magic_accuracy": {
      "description": "Calculate magic attack accuracy",
      "step_1_effective_magic": "floor(magic_level * 0.7 + defence_level * 0.3)",
      "step_2_attack_roll": "floor(effective_magic * (magic_attack_bonus + 64) / 64)",
      "step_3_defence_roll": "floor(effective_magic_defence * (magic_defence_bonus + 64) / 64)"
    },

    "magic_defence": {
      "description": "Magic defence uses unique calculation",
      "effective_defence": "floor(magic_level * 0.7 + defence_level * 0.3)",
      "defence_roll": "floor(effective_defence * (magic_defence_bonus + 64) / 64)"
    },

    "combat_level": {
      "description": "Calculate overall combat level",
      "base_level": "0.25 * (defence_level + hitpoints_level + prayer_level / 2)",
      "melee_component": "0.325 * (attack_level + strength_level)",
      "ranged_component": "0.325 * (ranged_level * 1.5)",
      "magic_component": "0.325 * (magic_level * 1.5)",
      "formula": "floor(base_level + max(melee_component, ranged_component, magic_component))",
      "notes": "Ranged and magic are multiplied by 1.5 for their component calculation"
    },

    "damage_reduction": {
      "description": "Defence damage mitigation",
      "damage_reduction_bonus": "Sum of all damage reduction bonuses (e.g., Justiciar)",
      "reduced_damage": "damage * (1 - damage_reduction_percentage)",
      "notes": "Applied after hit is calculated but before damage dealt"
    },

